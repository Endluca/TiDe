DATABASE_URL='postgresql+psycopg://<app_user>:<password>@<host>:5432/<database>?sslmode=disable&connect_timeout=8'
APP_ENV=test
TIT_SESSION_TTL_HOURS=8
AGENT_PROVIDER=deterministic
OPENAI_AGENT_MODEL=gpt-5.6-terra
AGENT_REASONING_EFFORT=low
AGENT_TIMEOUT_SECONDS=20
# Optional. Deterministic task triggering does not require an OpenAI key.
OPENAI_API_KEY=
